# Run PSO
print("Running PSO optimization...")
def pso_optimize(obj_func, bounds, args, n_particles=25, n_iterations=150):
    n_dims = len(bounds)
    pos = np.zeros((n_particles, n_dims))
    vel = np.zeros((n_particles, n_dims))
    for d in range(n_dims):
        pos[:, d] = np.random.uniform(bounds[d][0], bounds[d][1], n_particles)

    p_best_pos = pos.copy()
    p_best_val = np.array([obj_func(p, *args) for p in pos])
    g_best_idx = np.argmin(p_best_val)
    g_best_pos = p_best_pos[g_best_idx].copy()
    g_best_val = p_best_val[g_best_idx]

    w, c1, c2 = 0.7, 1.5, 1.5
    history = [g_best_val]

    for it in range(n_iterations):
        for i in range(n_particles):
            r1, r2 = np.random.random(n_dims), np.random.random(n_dims)
            vel[i] = w*vel[i] + c1*r1*(p_best_pos[i]-pos[i]) + c2*r2*(g_best_pos-pos[i])
            pos[i] += vel[i]
            for d in range(n_dims):
                pos[i, d] = np.clip(pos[i, d], bounds[d][0], bounds[d][1])

            val = obj_func(pos[i], *args)
            if val < p_best_val[i]:
                p_best_val[i] = val
                p_best_pos[i] = pos[i].copy()
                if val < g_best_val:
                    g_best_val = val
                    g_best_pos = pos[i].copy()
        w *= 0.99
        history.append(g_best_val)
        if it % 50 == 0:
            print(f"  PSO iter {it}: best={g_best_val:.2f}")

    return g_best_pos, g_best_val, history

