# ---- Method 4: SOPDT Least Squares ----
def sopdt_response_vec(t, K, T1, T2, tau, u_step, y0):
    t_eff = np.maximum(t - tau, 0)
    if abs(T1 - T2) < 1e-3:
        y_pred = y0 + K * u_step * (1 - (1 + t_eff/T1) * np.exp(-t_eff/T1))
    else:
        y_pred = y0 + K * u_step * (1 - (T1*np.exp(-t_eff/T1) - T2*np.exp(-t_eff/T2))/(T1-T2))
    y_pred[t < tau] = y0
    return y_pred

def objective_sopdt(params, t, y, u_step, y0):
    T1, T2, tau = params
    y_pred = sopdt_response_vec(t, K4_const, T1, T2, tau, u_step, y0)
    return np.sum((y - y_pred)**2)

