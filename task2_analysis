# ---- Method 1: Area Method ----
def area_method(t, y, u_step):
    y_inf_local = y[-1]
    y0_local = y[0]
    K = (y_inf_local - y0_local) / u_step
    y_n = (y - y0_local) / (y_inf_local - y0_local)
    A0 = np.trapezoid(1 - y_n, t)
    T_est = A0 / (1 + 0.1)
    tau_est = A0 - T_est
    return K, T_est, tau_est

K1, T1, tau1 = area_method(t, y, u_norm)
print(f"\n[Area Method] K={K1:.4f}, T={T1:.2f}, tau={tau1:.2f}")

# ---- Method 2: Two-Point Method ----
def two_point_method(t, y, u_step):
    y_inf_local = y[-1]
    y0_local = y[0]
    K = (y_inf_local - y0_local) / u_step
    y_n = (y - y0_local) / (y_inf_local - y0_local)
    t1 = np.interp(0.283, y_n, t)
    t2 = np.interp(0.632, y_n, t)
    T_est = 1.5 * (t2 - t1)
    tau_est = max(0, t2 - T_est)
    if tau_est < 1:
        tau_est = t1 * 0.1
        T_est = t2 - tau_est
    return K, T_est, tau_est

K2, T2, tau2 = two_point_method(t, y, u_norm)
print(f"\n[Two-Point Method] K={K2:.4f}, T={T2:.2f}, tau={tau2:.2f}")

# ---- Method 3: FOPDT Least Squares ----
# Vectorized FOPDT response
def fopdt_response_vec(t, K, T, tau, u_step, y0):
    y_pred = np.where(t >= tau, y0 + K * u_step * (1 - np.exp(-(t - tau) / T)), y0)
    return y_pred

def objective_fopdt(params, t, y, u_step, y0):
    T, tau = params
    y_pred = fopdt_response_vec(t, K3_const, T, tau, u_step, y0)
    return np.sum((y - y_pred)**2)

K3_const = (y[-1] - y[0]) / u_norm
