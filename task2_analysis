# Fast FOPDT + PID simulation (vectorized state-space)
def sim_pid_fast(K, T, tau, Kp, Ki, Kd, t_vec, dt, SP, y0):
    """Optimized simulation of PID-controlled FOPDT plant"""
    n = len(t_vec)
    y_out = np.zeros(n)
    u_out = np.zeros(n)
    y_out[0] = y0

    integral = 0.0
    prev_error = SP - y0
    delay_steps = int(np.ceil(tau / dt))
    u_buffer = np.zeros(delay_steps + 1)
    u_buffer[:] = u_norm

    # Precompute Euler step
    alpha = dt / T
    K_alpha = K * alpha

    for i in range(1, n):
        # Delayed input
        u_delayed = u_buffer[0]
        u_buffer[:-1] = u_buffer[1:]

        # PID
        error = SP - y_out[i-1]
        integral += error * dt

        # Clamp integral (anti-windup)
        integral = np.clip(integral, -50/Ki if Ki > 1e-9 else -50, 50/Ki if Ki > 1e-9 else 50)

        derivative = (error - prev_error) / dt
        prev_error = error

        u_raw = Kp * error + Ki * integral + Kd * derivative
        u_current = np.clip(u_raw, 0, 10)

        # Anti-windup back-calculation
        if abs(u_current - u_raw) > 1e-6:
            integral -= error * dt

        u_buffer[-1] = u_current
        u_out[i] = u_current

        # Plant dynamics (Euler)
        y_out[i] = y_out[i-1] + (K_alpha * u_delayed - alpha * y_out[i-1])

    return y_out, u_out

# Performance metrics
def calc_perf(t_vec, y_out, u_out, SP):
    err = SP - y_out
    n_ss = max(1, len(t_vec) // 5)
    y_ss = y_out[-n_ss:]
    steady_err = abs(np.mean(y_ss) - SP)
    overshoot = max(0, (np.max(y_out) - SP) / SP * 100) if np.max(y_out) > SP else 0

    # Rise time
    try:
        tr_start = np.interp(SP*0.1 + (1-0.1)*y_out[0], y_out, t_vec)
        tr_end = np.interp(SP*0.9, y_out, t_vec)
        rise_time = tr_end - tr_start
    except:
        rise_time = np.nan

    # Settling time (5% band)
    try:
        upper = SP * 1.05
        lower = SP * 0.95
        for i in range(len(y_out)-1, -1, -1):
            if y_out[i] > upper or y_out[i] < lower:
                settling_time = t_vec[min(i+1, len(t_vec)-1)]
                break
            settling_time = t_vec[-1]
    except:
        settling_time = np.nan

    peak_time = t_vec[np.argmax(y_out)]

    # Error integrals
    IAE = np.trapezoid(np.abs(err), t_vec)
    ISE = np.trapezoid(err**2, t_vec)
    ITAE = np.trapezoid(t_vec * np.abs(err), t_vec)

    # Decay ratio
    try:
        peaks = []
        for i in range(2, len(y_out)-1):
            if y_out[i] > y_out[i-1] and y_out[i] > y_out[i+1] and y_out[i] > SP:
                peaks.append(y_out[i])
        if len(peaks) >= 2:
            a1, a2 = peaks[0]-SP, peaks[1]-SP
            decay_ratio = (a1-a2)/a1 if a1 > 0 else 0
        else:
            decay_ratio = 0
    except:
        decay_ratio = 0

    return {'Steady-state Error': steady_err, 'Overshoot(%)': overshoot,
            'Rise Time(s)': rise_time, 'Settling Time(s)': settling_time,
            'Peak Time(s)': peak_time, 'IAE': IAE, 'ISE': ISE, 'ITAE': ITAE,
            'Decay Ratio': decay_ratio}

# Objective function for optimization
def obj_pid(params, K, T, tau, t_vec, dt, SP, y0):
    Kp, Ki, Kd = params
    try:
        y_sim, u_sim = sim_pid_fast(K, T, tau, Kp, Ki, Kd, t_vec, dt, SP, y0)
        err = SP - y_sim
        itae_val = np.trapezoid(t_vec * np.abs(err), t_vec)
        overshoot_val = max(0, np.max(y_sim) - SP) * 100
        # Penalize oscillations
        osc_pen = 0
        for i in range(3, len(y_sim)):
            if (y_sim[i]-y_sim[i-1]) * (y_sim[i-1]-y_sim[i-2]) < 0:
                osc_pen += abs(y_sim[i]-y_sim[i-1])
        J = itae_val * 0.01 + overshoot_val * 10 + osc_pen * 5
        return J
    except:
        return 1e10

